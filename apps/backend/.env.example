# =============================================================
# apps/backend/.env  (NÃO commitar — está no .gitignore)
# =============================================================
PORT=3001
NODE_ENV=development

# Supabase Service Role Key (para operações de admin no backend)
# Obtenha em: https://app.supabase.com > Settings > API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Database URL direta (para quando sair do Supabase)
# DATABASE_URL=postgresql://user:password@localhost:5432/soday
